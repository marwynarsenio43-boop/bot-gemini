# ZapBot Cloud — Variáveis de Ambiente
# Copie este ficheiro para .env para uso local
# No Render, adicione estas variáveis em Environment Variables

# ── Google Gemini ──────────────────────────────
GEMINI_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# ── WhatsApp Business API ──────────────────────
WA_TOKEN=EAAxxxxx...
WA_PHONE_ID=123456789012345
WA_APP_ID=123456789
WA_SECRET=abc123...

# ── Webhook ────────────────────────────────────
VERIFY_TOKEN=zapbot_verify_2024

# ── Servidor ───────────────────────────────────
PORT=3000

# ── Negócio (opcional — pode configurar pelo painel) ──
# BIZ_NAME=Minha Loja
# AGENT_NAME=Maria
# AGENT_PERSONA=amigavel
